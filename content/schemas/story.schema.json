{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://magium.local/schemas/story.schema.json",
  "title": "Magium canonical story graph",
  "type": "object",
  "required": ["formatVersion", "chapterId", "sourceFile", "sceneOrder", "scenes"],
  "properties": {
    "formatVersion": { "type": "integer", "const": 2 },
    "chapterId": { "type": "string" },
    "sourceFile": { "type": "string" },
    "sceneOrder": { "type": "array", "items": { "type": "string" } },
    "scenes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "blocks", "choices", "setVariables", "achievements"],
        "properties": {
          "id": { "type": "string" },
          "blocks": { "type": "array" },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "messageId", "target", "setVariables", "special", "conditions"],
              "properties": {
                "id": { "type": "string" },
                "messageId": { "type": "string" },
                "target": { "type": "string" },
                "setVariables": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/variableAssignment" }
                },
                "special": { "type": ["string", "null"] },
                "conditions": { "type": ["object", "null"] }
              }
            }
          },
          "setVariables": {
            "type": "array",
            "items": {
              "allOf": [
                { "$ref": "#/$defs/variableAssignment" },
                {
                  "type": "object",
                  "required": ["id", "conditions"],
                  "properties": {
                    "id": { "type": "string" },
                    "conditions": { "type": ["object", "null"] }
                  }
                }
              ]
            }
          },
          "achievements": { "type": "array" }
        }
      }
    }
  },
  "$defs": {
    "variableAssignment": {
      "type": "object",
      "required": ["variable", "mode", "value"],
      "properties": {
        "variable": { "type": "string" },
        "mode": { "enum": ["set", "add"] },
        "value": { "type": ["string", "number", "boolean"] }
      }
    }
  }
}
