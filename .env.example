MAGIUM_TRANSLATION_API_PORT=8090
MAGIUM_POSTGRES_PORT=5432
MAGIUM_MAILPIT_WEB_PORT=8025

VITE_MAGIUM_CONTRIBUTIONS_API_URL=http://localhost:8090
VITE_MAGIUM_TURNSTILE_SITE_KEY=

