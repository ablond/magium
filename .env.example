# Optional local overrides for `docker compose up -d`.
# The defaults in docker-compose.yml are sufficient for local development.

MAGIUM_WEB_PORT=5173
MAGIUM_APP_PORT=8090
MAGIUM_POSTGRES_PORT=5432
MAGIUM_MAILPIT_WEB_PORT=8025

VITE_MAGIUM_API_URL=/
VITE_MAGIUM_TURNSTILE_SITE_KEY=

POSTGRES_DB=magium_translation
POSTGRES_USER=magium_translation
POSTGRES_PASSWORD=magium_translation

MAGIUM_PUBLIC_API_URL=http://localhost:8090
MAGIUM_PUBLIC_WEB_URL=http://localhost:5173
MAGIUM_ALLOWED_ORIGIN=http://localhost:5173
MAGIUM_ADMIN_TOKEN=dev-admin-token
MAGIUM_ADMIN_PASSWORD=dev-admin-password
MAGIUM_ADMIN_SESSION_SECRET=dev-admin-session-secret
MAGIUM_ADMIN_COOKIE_SECURE=0
MAGIUM_ADMIN_SESSION_TTL_HOURS=8
MAGIUM_TURNSTILE_DISABLED=1
MAGIUM_TURNSTILE_SECRET_KEY=
MAGIUM_PSEUDONYM_BLOCKLIST=

MAGIUM_SMTP_URL=smtp://mailpit:1025
MAGIUM_EMAIL_FROM=Magium <no-reply@magium.app>
MAGIUM_EMAIL_WEBHOOK_URL=
MAGIUM_EMAIL_WEBHOOK_TOKEN=
MAGIUM_EMAIL_CONSENT_SECRET=dev-email-consent-secret

MAGIUM_GITHUB_TOKEN_FOR_DISPATCH=
MAGIUM_GITHUB_REPOSITORY_TARGET=
MAGIUM_GITHUB_WORKFLOW_FILE=translation-changeset-pr.yml
MAGIUM_GITHUB_REF_NAME=main

MAGIUM_SESSION_TTL_DAYS=30
MAGIUM_AUTH_RATE_LIMIT_WINDOW_MS=900000
MAGIUM_AUTH_RATE_LIMIT_MAX=10
MAGIUM_MAX_SYNC_BODY_BYTES=5000000
MAGIUM_MAX_SYNC_RECORDS=500
MAGIUM_TRUST_PROXY=0
