POSTGRES_USER=magium_translation
POSTGRES_PASSWORD=magium_translation

MAGIUM_TRANSLATION_PUBLIC_API_URL=http://localhost:8090
MAGIUM_TRANSLATION_PUBLIC_WEB_URL=http://localhost:5173
MAGIUM_TRANSLATION_ALLOWED_ORIGIN=http://localhost:5173
MAGIUM_TRANSLATION_ADMIN_TOKEN=dev-admin-token
MAGIUM_TRANSLATION_ADMIN_PASSWORD=dev-admin-password
MAGIUM_TRANSLATION_ADMIN_SESSION_SECRET=dev-admin-session-secret
MAGIUM_TRANSLATION_ADMIN_COOKIE_SECURE=0
MAGIUM_TRANSLATION_ADMIN_SESSION_TTL_HOURS=8
