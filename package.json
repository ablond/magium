{
  "name": "magium",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ablond/magium.git"
  },
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm content:all && vite build && pnpm dist:check",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "pnpm content:all && vitest run --exclude tests/manual-images.test.mjs && pnpm test:server",
    "test:server": "pnpm --dir services/translation-api test",
    "content:import": "node tools/content/import-original.mjs",
    "content:archive:check": "node tools/content/archive-check.mjs",
    "content:parse": "node tools/content/build-canonical.mjs",
    "content:validate": "node tools/content/validate-content.mjs",
    "content:all": "pnpm content:import && pnpm content:archive:check && pnpm content:parse && pnpm content:validate",
    "images:prompts": "node tools/images/generate-prompts.mjs",
    "images:stage": "node tools/images/stage-chatgpt.mjs",
    "images:normalize": "node tools/images/normalize-illustrations.mjs",
    "images:refsheets": "node tools/images/create-refsheets.mjs",
    "images:generate:api": "node tools/images/generate-api.mjs",
    "images:check": "node tools/images/check-images.mjs",
    "images:test": "pnpm content:all && vitest run tests/manual-images.test.mjs",
    "dist:check": "node tools/content/check-dist.mjs",
    "docker:build-prod": "tools/docker/build-prod-push.sh",
    "docker:push-prod": "tools/docker/build-prod-push.sh --push"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.13.2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@fontsource-variable/literata": "^5.2.8",
    "@lucide/svelte": "^1.23.0"
  }
}
